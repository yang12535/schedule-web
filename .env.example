# ========================================
# 班级课表服务 - 环境配置示例
# 复制为 .env 后修改
# ========================================

# 基础配置
CLASS_NAME=计算机网络1班
CLASS_DESC=2024年春季学期
SEMESTER_START=2024-03-01

# 安全设置
# 留空表示无需密码，否则设置6位数字密码
EDIT_PASSWORD=

# 服务端口（Docker部署使用）
HOST_PORT=30080

# 数据存储路径（相对于 docker-compose.yml）
DATA_PATH=./data
LOGS_PATH=./logs
